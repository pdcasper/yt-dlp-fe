{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "yt-dlp-fe",
  "version": "0.3.0",
  "identifier": "com.pdcasper.yt-dlp-fe",
  "build": {
    "frontendDist": "../src",
    "devtools": true
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "yt-dlp-fe - Download YouTube to MP3",
        "width": 500,
        "height": 400,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "resources": {
      "resources/*": "./"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app", "msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "resources/*": "./"
    }
  }
}
